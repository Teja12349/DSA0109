#include <iostream>
using namespace std;
int main()
{
    int n, square, temp, digits = 0;
    cout << "Enter a number: ";
    cin >> n;
    square = n * n;
    temp = n;
    while(temp > 0)
    {
        digits++;
        temp /= 10;
    }
    int divisor = 1;
    for(int i = 1; i <= digits; i++)
        divisor *= 10;
    if(square % divisor == n)
        cout << "Automorphic Number";
    else
        cout << "Not an Automorphic Number";
    return 0;
}
