#include <iostream>
using namespace std;
int main()
{
    int n, num;
    int positiveSum = 0, negativeSum = 0;
    cout << "Enter the number of elements: ";
    cin >> n;
    cout << "Enter the numbers:\n";
    for(int i = 1; i <= n; i++)
    {
        cin >> num;
        if(num > 0)
            positiveSum += num;
        else if(num < 0)
            negativeSum += num;
    }
    cout << "Sum of Positive Numbers = " << positiveSum << endl;
    cout << "Sum of Negative Numbers = " << negativeSum << endl;
    return 0;
}
