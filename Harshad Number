#include <iostream>
using namespace std;
int main()
{
    int n, temp, sum = 0;
    cout << "Enter a number: ";
    cin >> n;
    temp = n;
    while(temp > 0)
    {
        sum += temp % 10;
        temp /= 10;
    }
    if(n % sum == 0)
        cout << "Harshad Number";
    else
        cout << "Not a Harshad Number";
    return 0;
}
